import math
n = int(input("Nhap so nguyen duong n = "))
while n <= 0 :
    n = int(input(" Nhap lai n = "))
if n < 2:
    print ( "Khong phai la so nguyen to")
else :
    nguyenTo = True 
    for i in range (2,int(math.sqrt(n)+1)):
        if n % i == 0:
            nguyenTo = False
            break
    if nguyenTo :
        print (n," la so nguyen to")
    else :
        print (n," khong la so nguyen to")
